{
  "name": "cloudflare-workers-containers-hono-template",
  "description": "Hono-powered Cloudflare Worker that routes requests to a serverless Container backend (Workers Containers) via @cloudflare/containers.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --env local --port 8001 --inspector-port 9230 --persist-to ../.wrangler/state",
    "dev:docker": "docker compose up --build",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:studio": "drizzle-kit studio",
    "db:studio:remote": "REMOTE=1 drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate:dev": "wrangler d1 migrations apply DB --env dev --remote",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "prepare": "husky",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "bun run prettier src/ --write",
    "bun:dev": "bun run --watch src/index.ts",
    "bun:start": "bun run src/index.ts",
    "bun:build": "bun build src/index.ts --compile --outfile server",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@d3avarja/try-catch": "^0.0.1",
    "@hono/swagger-ui": "^0.5.3",
    "@hono/zod-openapi": "^1.2.2",
    "@hono/zod-validator": "^0.7.6",
    "better-auth": "1.4.18",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.9",
    "jiti": "^2.6.1",
    "loglevel": "^1.9.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.4.1",
    "@deox/drizzle-d1-utils": "^0.0.1",
    "better-sqlite3": "^12.6.2",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0",
    "wrangler": "^4.65.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss,html,yml,yaml}": [
      "prettier --write"
    ]
  }
}
